# StairTrain (vertical) — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing live tokens.

# OneMap API credentials (for Phase 0 ingestion script)
# Register at: https://www.onemap.gov.sg/ (free, Singapore government API)
# Token expires every 3 days — the ingestion script re-authenticates each run.
ONEMAP_EMAIL=your_email@example.com
ONEMAP_PASSWORD=your_password_here

# Supabase (Postgres + PostGIS)
# Create a free project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
