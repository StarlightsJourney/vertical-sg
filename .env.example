# Vertical — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing live tokens.

# ============================================
# Supabase (Postgres + PostGIS)
# ============================================
# Get these from: Supabase Dashboard → Project Settings → Data API

# Project URL — shown as "Project URL" in Supabase dashboard
# This is safe to include in the mobile app (it's just an endpoint).
SUPABASE_URL=https://your-project.supabase.co

# Anon / Publishable key — starts with "eyJ..."
# Safe for client-side use (mobile app). Respects Row Level Security.
# Shown as "anon public" key in Supabase dashboard.
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — starts with "eyJ..."
# SERVER-SIDE ONLY. Bypasses Row Level Security.
# Used by the ingestion script (Phase 0) only — NEVER put this in the mobile app.
# Shown as "service_role secret" in Supabase dashboard.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# OneMap API (Singapore government geocoding)
# ============================================
# Register at: https://www.onemap.gov.sg/ (free)
# Two auth options — use whichever you have:

# Option A: Email + Password (script auto-fetches a JWT each run)
ONEMAP_EMAIL=your_email@example.com
ONEMAP_PASSWORD=your_password_here

# Option B: Direct API token (if you already have a valid JWT)
# Token expires every 3 days — prefer Option A for automation.
ONEMAP_TOKEN=
